# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme

# ── Evidently Exporter ─────────────────────────────────────────────────────────
# Paths are container-internal (mounted from DATA_ROOT below)
REFERENCE_DATA_PATH=/data/reference.csv
CURRENT_DATA_PATH=/data/current.csv
TARGET_COLUMN=Label
DRIFT_INTERVAL_SECONDS=300

# ── Volume mount: host path mounted as /data inside the exporter container ─────
DATA_ROOT=../Model/data
