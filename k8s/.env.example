# ─────────────────────────────────────────
#  .env.example
#  Copier en .env et remplir avec tes valeurs
#  cp .env.example .env
# ─────────────────────────────────────────

# DagsHub credentials (DVC + MLflow remote)
DAGSHUB_USER=ton_username_dagshub
DAGSHUB_TOKEN=ton_token_dagshub

# MLflow tracking server
MLFLOW_USER=ton_username
MLFLOW_PWD=ton_password

# Image registry (optionnel — si tu utilises un registry privé)
# IMAGE_REGISTRY=ghcr.io/oussamaelmoussaoui
# IMAGE_TAG=1.0.0
